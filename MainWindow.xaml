<Window x:Class="POE_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="500" Width="900">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <RichTextBox Grid.Row="0"
             Foreground="Cyan"
             Background="Transparent"
             BorderThickness="0"
             FontFamily="Consolas"
             FontSize="14"
             IsReadOnly="True"
             HorizontalAlignment="Center"
             Margin="10">
            <FlowDocument>
                <Paragraph xml:space="preserve">
              _______     ______  ______ _____  
             / ____\ \   / /  _ \|  ____|  __ \ 
            | |     \ \_/ /| |_) | |__  | |__) |
            | |      \   / |  _  |  __| |  _  / 
            | |____   | |  | |_) | |____| | \ \ 
             \_____|  |_|  |____/|______|_|  \_\
                                                  
                CYBERSECURITY AWARENESS BOT
        </Paragraph>
    </FlowDocument>
</RichTextBox>



        <!-- Chat History -->
        <ListBox x:Name="lstChat" Grid.Row="1" 
                 Background="Black" Foreground="White" 
                 FontFamily="Consolas" FontSize="14" 
                 Margin="10"/>

        <!-- User Input + Send Button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
            <TextBox x:Name="txtUserInput" Width="600" Height="30" FontSize="14"/>
            <Button x:Name="btnSend" Content="Send" Width="100" Height="30" Margin="10,0,0,0"
                    Click="btnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>
