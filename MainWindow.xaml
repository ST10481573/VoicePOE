<Window x:Class="POE_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="600" Width="900"
        Background="#1E1E1E">

    <Grid>
        <TabControl>
            <!-- Chatbot Tab -->
            <TabItem Header="Chatbot">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ASCII Art Banner -->
                    <RichTextBox Grid.Row="0"
                                 Foreground="Cyan"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 IsReadOnly="True"
                                 HorizontalAlignment="Center"
                                 Margin="10">
                        <FlowDocument>
                            <Paragraph xml:space="preserve">
              _______     ______  ______ _____  
             / ____\ \   / /  _ \|  ____|  __ \ 
            | |     \ \_/ /| |_) | |__  | |__) |
            | |      \   / |  _  |  __| |  _  / 
            | |____   | |  | |_) | |____| | \ \ 
             \_____|  |_|  |____/|______|_|  \_\
                                                  
                CYBERSECURITY AWARENESS BOT
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>

                    <!-- Chat History -->
                    <ListBox x:Name="lstChat" Grid.Row="1"
                             Background="Black" Foreground="White"
                             FontFamily="Consolas" FontSize="14"
                             Margin="10"/>

                    <!-- User Input -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
                        <TextBox x:Name="txtUserInput" Width="600" Height="30" FontSize="14"/>
                        <Button x:Name="btnSend" Content="Send" Width="100" Height="30" Margin="10,0,0,0"
                                Click="btnSend_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tasks Tab -->
            <TabItem Header="Tasks">
                <StackPanel Margin="10">
                    <TextBox x:Name="TaskTitle" Width="400" Height="30" Margin="0,0,0,5"/>
                    <TextBox x:Name="TaskDescription" Width="400" Height="60" Margin="0,0,0,5" TextWrapping="Wrap"/>
                    <DatePicker x:Name="ReminderDate" Margin="0,0,0,5"/>
                    <Button Content="Add Task" Click="AddTask_Click" Width="120" Margin="0,0,0,10"/>
                    <ListView x:Name="TaskList" Height="300"/>
                </StackPanel>
            </TabItem>

            <!-- Quiz Tab -->
            <!-- Quiz Tab -->
            <TabItem Header="Quiz">
                <StackPanel Margin="10">
                    <!-- Question Text -->
                    <TextBlock x:Name="QuizQuestion" 
                   FontWeight="Bold" 
                   Foreground="White" 
                   FontSize="16" 
                   TextWrapping="Wrap" 
                   Margin="0,0,0,10"/>

                    <Button Content="Start Quiz" 
        Click="StartQuiz_Click" 
        Width="150" 
        Margin="0,0,0,10"/>


                    <!-- Options (Radio Buttons) -->
                    <ListBox x:Name="QuizOptions" 
                 Background="Black" 
                 Foreground="White" 
                 FontSize="14" 
                 Margin="0,0,0,10"
                 SelectionMode="Single"/>

                    <!-- Submit Button -->
                    <Button Content="Submit Answer" 
                Click="SubmitAnswer_Click" 
                Width="150" 
                Margin="0,10,0,0"/>

                    <!-- Feedback -->
                    <TextBlock x:Name="QuizFeedback" 
                   Foreground="Cyan" 
                   FontStyle="Italic" 
                   Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>


            <!-- Activity Log Tab -->
            <TabItem Header="Activity Log">
                <StackPanel Margin="10">
                    <ListBox x:Name="ActivityLog" Height="400" Background="Black" Foreground="White"/>
                    <Button Content="Refresh Log" Click="RefreshLog_Click" Width="120"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
